<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro">
    <!-- Material Tags. -->
    <material name="Red">
        <color rgba="1 0 0 0.5" />
    </material>

    <material name="Green">
        <color rgba="0 1 0 0.5" />
    </material>

    <material name="Blue">
        <color rgba="0 0 1 0.5" />
    </material>

    <material name="Gray">
        <color rgba="0.5 0.5 0.5 0.5" />
    </material>
</robot>